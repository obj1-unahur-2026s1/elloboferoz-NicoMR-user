import feroz.feroz
import caperucita.caperucita
import personajes.abuelita
import personajes.cazador





object historia {

  method contar() {

    feroz.correr("bosque")

    feroz.correr("casa abuelita")

    feroz.comer(abuelita)

    caperucita.perderManzana()

    feroz.comer(caperucita)

    cazador.atacar(feroz)

  }

}